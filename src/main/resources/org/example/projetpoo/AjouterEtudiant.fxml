<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox spacing="15" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.projetpoo.AjouterEtudiantController">

    <Label text="Ajouter un étudiant" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <Label text="Nom"/>
    <TextField fx:id="champNom" promptText="Nom"/>

    <Label text="Prénom"/>
    <TextField fx:id="champPrenom" promptText="Prénom"/>

    <Label text="Identifiant"/>
    <TextField fx:id="champId" promptText="Identifiant"/>

    <Label text="Cote R"/>
    <TextField fx:id="champCoteR" promptText="Cote R"/>

    <HBox spacing="10">
        <Button text="Annuler" onAction="#annuler"/>
        <Button text="Ajouter" onAction="#ajouter"/>
    </HBox>

</VBox>